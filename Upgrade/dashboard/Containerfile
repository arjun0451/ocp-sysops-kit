# =============================================================================
# OCP Upgrade Health Check Dashboard
# Base: Red Hat Universal Base Image 9 — Node.js 20
# Build: podman build -t ocp-dashboard .
# Run:   see run.sh
# =============================================================================

FROM registry.access.redhat.com/ubi9/nodejs-20:latest

# Switch to root to set up directories
USER root

# App directory inside the container
WORKDIR /app

# Copy package files first (layer cache)
COPY package.json package-lock.json* ./

# Install only production deps
RUN npm install --omit=dev && npm cache clean --force

# Copy app source
COPY server.js ./
COPY public/  ./public/

# The script and artifacts live on the HOST and are bind-mounted at runtime.
# The container only runs the web server — the script runs on the host terminal.
# Default mount points (override with -e flags):
#   SCRIPT_PATH  = /scripts/ocp-upgrade-healthcheck-v6.sh
#   ARTIFACT_DIR = /artifacts
RUN mkdir -p /scripts /artifacts && chown -R 1001:1001 /scripts /artifacts

# Drop privileges — run as UID 1001 (default non-root in UBI images)
USER 1001

ENV PORT=8080 \
    SCRIPT_PATH=/scripts/ocp-upgrade-healthcheck-v6.sh \
    ARTIFACT_BASE=/artifacts \
    NODE_ENV=production

EXPOSE 8080

# Health check — simple TCP probe on the API
HEALTHCHECK --interval=15s --timeout=5s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:8080/api/status', r => process.exit(r.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))"

CMD ["node", "server.js"]
